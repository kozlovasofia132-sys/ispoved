# YooKassa Webhook Configuration
# Copy this file to .env and fill in your actual values

# YooKassa webhook secret key for signature verification
# Get this from your YooKassa merchant dashboard
YOOKASSA_WEBHOOK_SECRET=your_webhook_secret_key_here

# Server configuration
PORT=3000
NODE_ENV=development

# Log file path
LOG_FILE_PATH=./logs/payments.log
