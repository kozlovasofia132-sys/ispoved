# YooKassa Configuration
# ⚠️ НЕ КОММИТИТЬ ЭТОТ ФАЙЛ В GIT!

# Идентификатор магазина
YOOKASSA_SHOP_ID=1314617

# Секретный ключ для API
YOOKASSA_SECRET_KEY=live_твой_ключ_здесь

# Порт сервера
PORT=3000

# URL для возврата после оплаты (на фронтенд)
